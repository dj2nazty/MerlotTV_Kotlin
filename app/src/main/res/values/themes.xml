<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base dark theme matching the HTML UI exactly -->
    <style name="Theme.MerlotTV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:colorPrimary">@color/accent</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Fully immersive fullscreen for the WebView activity -->
    <style name="Theme.MerlotTV.Fullscreen" parent="Theme.MerlotTV">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Player activity theme (ExoPlayer) -->
    <style name="Theme.MerlotTV.Player" parent="Theme.MerlotTV.Fullscreen">
        <item name="android:windowBackground">@android:color/black</item>
    </style>

</resources>
