<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MerlotTV" parent="Theme.Leanback">
        <item name="colorPrimary">@color/merlot_primary</item>
        <item name="colorPrimaryDark">@color/merlot_primary_dark</item>
        <item name="colorAccent">@color/merlot_accent</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowOverscan">true</item>
    </style>

    <style name="Theme.MerlotTV.Player" parent="Theme.MerlotTV">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowOverscan">true</item>
    </style>

    <style name="Theme.MerlotTV.Settings" parent="ThemeOverlay.AppCompat">
        <item name="colorPrimary">@color/merlot_primary</item>
        <item name="colorAccent">@color/merlot_accent</item>
    </style>

    <style name="MerlotCard" parent="Widget.Leanback.ImageCardView">
        <item name="lbImageCardViewType">ImageOnly</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>

</resources>