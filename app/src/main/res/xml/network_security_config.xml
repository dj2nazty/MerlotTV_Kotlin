<?xml version="1.0" encoding="utf-8"?>
<!--
  IPTV streams are almost universally served over plain HTTP.
  This config allows cleartext traffic to any host.
  The manifest already has android:usesCleartextTraffic="true" as a belt-and-suspenders measure.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
